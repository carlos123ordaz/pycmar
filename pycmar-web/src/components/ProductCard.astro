---
import { getImageUrl } from '../lib/supabase';
import { pName, translateOrigin } from '../lib/i18n';
import type { Lang } from '../lib/i18n';
import type { Product } from '../lib/types';

interface Props {
  product: Product;
  lang?: Lang;
}

const { product: p, lang = 'es' } = Astro.props;
const name = pName(p, lang);
const mainImg = p.images?.find(i => i.is_main) ?? p.images?.[0] ?? null;
const catName = lang === 'zh'
  ? ((p.category as any)?.name_zh ?? (p.category as any)?.name_en ?? (p.category as any)?.name_es)
  : lang === 'es'
  ? (p.category as any)?.name_es
  : ((p.category as any)?.name_en ?? (p.category as any)?.name_es);
---

<a href={`/catalogo/${p.slug}`} class="pcard" style="text-decoration:none;">
  <div class="pcard-img">
    {mainImg
      ? <img src={getImageUrl('product-images', mainImg.url)} alt={name} loading="lazy" />
      : <div class="ph" style="height:100%;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
        </div>
    }
    <div class="pcard-tags">
      {p.tags.map(tg => <span class={`tag tag-${tg}`}>{tg}</span>)}
    </div>
  </div>
  <div class="pcard-body">
    {p.scientific_name && <div class="sci">{p.scientific_name}</div>}
    <h3>{name}</h3>
    {(p.origin || p.fao_zone) && (
      <div class="meta">
        {p.origin && <span>{translateOrigin(p.origin, lang)}</span>}
        {p.origin && p.fao_zone && <span class="dot"></span>}
        {p.fao_zone && <span>FAO {p.fao_zone}</span>}
      </div>
    )}
    <div class="pcard-foot">
      <div class="price">
        <span class="v">S/ {p.price.toFixed(2)}</span>
        <span class="u">/ kg</span>
      </div>
      <button
        class="pcard-add"
        data-id={p.id}
        data-name={name}
        data-name-es={p.name_es}
        data-name-en={p.name_en}
        data-name-zh={p.name_zh || ''}
        data-price={p.price}
        aria-label="Agregar"
        onclick="event.preventDefault(); _addToCart(this);"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
    </div>
  </div>
</a>

<script>
  function _flyToCart(btn: HTMLButtonElement) {
    const cart = document.getElementById('cart-open-btn');
    if (!cart) return;
    const btnRect = btn.getBoundingClientRect();
    const cartRect = cart.getBoundingClientRect();
    const startX = btnRect.left + btnRect.width / 2;
    const startY = btnRect.top + btnRect.height / 2;
    const endX = cartRect.left + cartRect.width / 2;
    const endY = cartRect.top + cartRect.height / 2;
    const dx = endX - startX;
    const dy = endY - startY;
    const arc = Math.max(40, Math.min(Math.abs(dx) * 0.4, 100));

    const dot = document.createElement('div');
    dot.style.cssText = `position:fixed;left:${startX}px;top:${startY}px;width:18px;height:18px;border-radius:50%;background:var(--accent-600,#0ea5e9);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);box-shadow:0 2px 8px rgba(0,0,0,.3);`;
    document.body.appendChild(dot);

    const duration = 520;
    const startTime = performance.now();

    function easeInOut(t: number) { return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t; }

    function step(now: number) {
      const t = Math.min((now - startTime) / duration, 1);
      const et = easeInOut(t);
      const x = dx * et;
      const y = dy * et - arc * Math.sin(t * Math.PI);
      const scale = 1 - t * 0.55;
      const opacity = t > 0.72 ? (1 - t) / 0.28 : 1;
      dot.style.transform = `translate(calc(-50% + ${x}px),calc(-50% + ${y}px)) scale(${scale})`;
      dot.style.opacity = String(opacity);
      if (t < 1) { requestAnimationFrame(step); }
      else { dot.remove(); document.dispatchEvent(new CustomEvent('cart-bounce')); }
    }

    requestAnimationFrame(step);
  }

  function _addToCart(btn: Element) {
    const b = btn as HTMLButtonElement;
    const id = b.dataset.id!;
    const name = b.dataset.name!;
    const name_es = b.dataset.nameEs || name;
    const name_en = b.dataset.nameEn || name;
    const name_zh = b.dataset.nameZh || '';
    const price = parseFloat(b.dataset.price!);
    const cart = JSON.parse(localStorage.getItem('pycmar_cart') || '[]');
    const existing = cart.find((i: any) => i.id === id);
    if (existing) { existing.qty += 1; } else { cart.push({ id, name, name_es, name_en, name_zh, price, qty: 1, mode: 'buy' }); }
    localStorage.setItem('pycmar_cart', JSON.stringify(cart));
    const total = cart.reduce((s: number, i: any) => s + i.qty, 0);
    const badge = document.getElementById('cart-count');
    if (badge) { badge.textContent = String(total); badge.style.display = 'flex'; }
    b.classList.add('added');
    setTimeout(() => b.classList.remove('added'), 1500);
    _flyToCart(b);
    document.dispatchEvent(new CustomEvent('cart-updated'));
  }

  (window as any)._addToCart = _addToCart;
</script>
