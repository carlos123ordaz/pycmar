---
import type { Lang } from '../lib/i18n';
import { t } from '../lib/i18n';

interface Props {
  currentPath?: string;
  lang: Lang;
}

const { currentPath = '/', lang } = Astro.props;
const from = encodeURIComponent(currentPath);

const navLinks = [
  { href: '/',            key: 'nav_home' },
  { href: '/exportacion', key: 'nav_export' },
  { href: '/contacto',    key: 'nav_contact' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const adminLabel = lang === 'zh' ? '管理员' : lang === 'en' ? 'Admin Portal' : 'Portal Admin';
---

<!-- Announce bar -->
<div class="announce">
  <span class="chev-acc">›› </span>
  <span class="announce-txt"><strong>HACCP · SANIPES · FDA</strong> — {t('announce_text', lang)}</span>
</div>

<!-- Header -->
<header class="header" id="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label="Pycmar">
      <img src="/assets/logo-navy.png" alt="PYCMAR — Procesos y Congelados del Mar" height="34" style="width:auto;" />
    </a>

    <!-- Desktop nav -->
    <nav class="nav">
      {navLinks.map(({ href, key }) => (
        <a href={href} class:list={[{ active: isActive(href) }]}>
          {t(key, lang)}
        </a>
      ))}
    </nav>

    <!-- Search bar -->
    <div class="search-wrap" id="search-wrap">
      <svg class="si" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder={t('search', lang)}
        autocomplete="off"
      />
      <div class="search-results" id="search-results" style="display:none;"></div>
    </div>

    <!-- Actions -->
    <div class="header-actions">

      <!-- Lang dropdown (globe icon) -->
      <div class="lang-dropdown" id="lang-dropdown">
        <button class="icon-btn lang-globe-btn" id="lang-globe-btn" aria-label="Language" aria-expanded="false" aria-haspopup="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="19" height="19">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          <span class="lang-label">{lang === 'zh' ? '中' : lang.toUpperCase()}</span>
        </button>
        <div class="lang-menu" id="lang-menu" role="menu">
          <a href={`/api/lang?lang=es&from=${from}`} class:list={[{ on: lang === 'es' }]} role="menuitem">
            <span class="lf">🇵🇪</span>
            <span>Español</span>
            {lang === 'es' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="13" height="13" style="margin-left:auto"><path d="M20 6L9 17l-5-5"/></svg>}
          </a>
          <a href={`/api/lang?lang=en&from=${from}`} class:list={[{ on: lang === 'en' }]} role="menuitem">
            <span class="lf">🇺🇸</span>
            <span>English</span>
            {lang === 'en' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="13" height="13" style="margin-left:auto"><path d="M20 6L9 17l-5-5"/></svg>}
          </a>
          <a href={`/api/lang?lang=zh&from=${from}`} class:list={[{ on: lang === 'zh' }]} role="menuitem">
            <span class="lf">🇨🇳</span>
            <span>中文</span>
            {lang === 'zh' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="13" height="13" style="margin-left:auto"><path d="M20 6L9 17l-5-5"/></svg>}
          </a>
        </div>
      </div>

      <!-- Admin portal -->
      <a href="https://admin-pycmar.vercel.app" target="_blank" rel="noopener noreferrer" class="icon-btn admin-link" title={adminLabel} aria-label={adminLabel}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="19" height="19">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
        </svg>
      </a>

      <!-- Cart -->
      <button class="icon-btn" id="cart-open-btn" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cart-count" id="cart-count" style="display:none">0</span>
      </button>

      <!-- Hamburger -->
      <button class="icon-btn hamburger" id="mobile-menu-btn" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<!-- Mobile menu -->
<div id="mobile-menu" class="overlay" style="display:none;">
  <div class="drawer" style="width:min(360px,100vw);" onclick="event.stopPropagation()">
    <div class="drawer-head">
      <a href="/" class="logo">
        <img src="/assets/logo-navy.png" alt="PYCMAR" height="34" style="width:auto;" />
      </a>
      <button class="icon-btn" id="mobile-close-btn" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="drawer-body">
      <div style="display:flex;flex-direction:column;gap:4px;">
        {navLinks.map(({ href, key }) => (
          <a
            href={href}
            style={`padding:14px 6px;font-size:1.1rem;font-weight:700;border-bottom:1px solid var(--line);color:${isActive(href) ? 'var(--accent-600)' : 'var(--navy)'};display:flex;align-items:center;justify-content:space-between;`}
          >
            {t(key, lang)}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        ))}
        <a
          href="/admin"
          style="padding:14px 6px;font-size:1.1rem;font-weight:700;border-bottom:1px solid var(--line);color:var(--navy);display:flex;align-items:center;justify-content:space-between;"
        >
          {adminLabel}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </a>
      </div>

      <!-- Language selector -->
      <div style="margin-top:22px;">
        <div style="font-size:.72rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--gray);margin-bottom:12px;display:flex;align-items:center;gap:6px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          {lang === 'zh' ? '语言' : lang === 'en' ? 'Language' : 'Idioma'}
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <a href={`/api/lang?lang=es&from=${from}`}
             class:list={['lang-mb', { 'lang-mb-on': lang === 'es' }]}>
            🇵🇪 ES
          </a>
          <a href={`/api/lang?lang=en&from=${from}`}
             class:list={['lang-mb', { 'lang-mb-on': lang === 'en' }]}>
            🇺🇸 EN
          </a>
          <a href={`/api/lang?lang=zh&from=${from}`}
             class:list={['lang-mb', { 'lang-mb-on': lang === 'zh' }]}>
            🇨🇳 中
          </a>
        </div>
      </div>

      <a
        class="btn btn-wa btn-block"
        style="margin-top:20px;"
        href="https://wa.me/51987486981"
        target="_blank"
        rel="noopener"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>
  </div>
</div>

<script>
  // Header scroll effect
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }

  // Cart bounce
  document.addEventListener('cart-bounce', () => {
    const btn = document.getElementById('cart-open-btn');
    if (!btn) return;
    btn.classList.remove('cart-popping');
    void (btn as HTMLElement).offsetWidth;
    btn.classList.add('cart-popping');
    btn.addEventListener('animationend', () => btn.classList.remove('cart-popping'), { once: true });
  });

  // Mobile menu
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    (document.getElementById('mobile-menu') as HTMLElement).style.display = 'block';
  });
  document.getElementById('mobile-close-btn')?.addEventListener('click', () => {
    (document.getElementById('mobile-menu') as HTMLElement).style.display = 'none';
  });
  document.getElementById('mobile-menu')?.addEventListener('click', function(e) {
    if (e.target === this) (this as HTMLElement).style.display = 'none';
  });

  // Lang dropdown
  const langDropdown = document.getElementById('lang-dropdown');
  const langGlobeBtn = document.getElementById('lang-globe-btn');

  langGlobeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = langDropdown?.classList.contains('open');
    langDropdown?.classList.toggle('open');
    langGlobeBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!langDropdown?.contains(e.target as Node)) {
      langDropdown?.classList.remove('open');
      langGlobeBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Live search
  const searchInput   = document.getElementById('search-input') as HTMLInputElement | null;
  const searchResults = document.getElementById('search-results') as HTMLElement | null;

  if (searchInput && searchResults) {
    const lang = document.documentElement.lang || 'es';
    let debounce: ReturnType<typeof setTimeout>;

    function hideResults() {
      searchResults!.style.display = 'none';
      searchResults!.innerHTML = '';
    }

    searchInput.addEventListener('input', () => {
      clearTimeout(debounce);
      const q = searchInput.value.trim();
      if (q.length < 2) { hideResults(); return; }

      debounce = setTimeout(async () => {
        try {
          const res  = await fetch(`/api/search?q=${encodeURIComponent(q)}&lang=${lang}`);
          const data = await res.json() as { id: string; name: string; cat: string; slug: string; img: string }[];

          if (!data.length) { hideResults(); return; }

          searchResults.innerHTML = data.map(p => `
            <a href="/catalogo/${p.slug}">
              <div class="thumb">
                <img src="${p.img}" alt="${p.name}" width="42" height="42"
                     style="width:42px;height:42px;object-fit:cover;"
                     onerror="this.style.display='none'">
              </div>
              <div>
                <div class="sr-name">${p.name}</div>
                <div class="sr-cat">${p.cat ?? ''}</div>
              </div>
            </a>
          `).join('');

          searchResults.style.display = 'block';
        } catch { hideResults(); }
      }, 280);
    });

    searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const q = searchInput.value.trim();
        if (q) { hideResults(); window.location.href = `/catalogo?q=${encodeURIComponent(q)}`; }
      }
      if (e.key === 'Escape') { hideResults(); searchInput.blur(); }
    });

    document.addEventListener('click', (e) => {
      if (!searchInput.closest('.search-wrap')?.contains(e.target as Node)) hideResults();
    });
  }
</script>

<style>
  @keyframes cart-pop {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.45); }
    55%  { transform: scale(0.88); }
    78%  { transform: scale(1.12); }
    100% { transform: scale(1); }
  }
  #cart-open-btn.cart-popping {
    animation: cart-pop 0.42s cubic-bezier(.36,.07,.19,.97) both;
  }

  /* ── Lang dropdown ────────────────────────────── */
  .lang-dropdown { position: relative; }

  .lang-globe-btn {
    display: flex !important;
    align-items: center;
    gap: 5px;
    padding: 0 10px !important;
    width: auto !important;
  }
  .lang-label {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .04em;
    line-height: 1;
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    min-width: 152px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-6px) scale(.97);
    pointer-events: none;
    transition: opacity .15s var(--ease), transform .15s var(--ease);
    z-index: 200;
  }
  .lang-dropdown.open .lang-menu {
    opacity: 1;
    transform: none;
    pointer-events: all;
  }
  .lang-menu a {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 11px 14px;
    font-size: .9rem;
    font-weight: 600;
    color: var(--navy);
    transition: background .1s;
    text-decoration: none;
  }
  .lang-menu a:hover { background: var(--mist); }
  .lang-menu a.on { color: var(--accent-600); background: var(--accent-050); }
  .lf { font-size: 1.1rem; line-height: 1; }

  /* ── Admin link ───────────────────────────────── */
  .admin-link {
    border: 1.5px solid var(--line-2) !important;
    color: var(--gray) !important;
  }
  .admin-link:hover {
    border-color: var(--navy) !important;
    background: var(--mist) !important;
    color: var(--navy) !important;
  }

  /* ── Mobile lang buttons ──────────────────────── */
  .lang-mb {
    padding: 8px 13px;
    border-radius: 9px;
    font-weight: 700;
    font-size: .88rem;
    border: 1.5px solid var(--line-2);
    background: #fff;
    color: var(--gray);
    text-decoration: none;
    transition: .16s;
  }
  .lang-mb:hover { border-color: var(--navy); color: var(--navy); }
  .lang-mb-on {
    border-color: var(--accent-600) !important;
    background: var(--accent-050) !important;
    color: var(--accent-600) !important;
  }

  @media(max-width:900px) {
    .nav { display: none; }
    .search-wrap { display: none; }
    .hamburger { display: flex !important; }
    .lang-dropdown { display: none !important; }
    .admin-link { display: none !important; }
  }
</style>
