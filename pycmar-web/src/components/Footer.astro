---
import type { Lang } from '../lib/i18n';
import { t, markets, certs } from '../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">

      <!-- Brand -->
      <div>
        <a href="/" class="logo" aria-label="Pycmar">
          <img src="/assets/logo-white.png" alt="PYCMAR" height="34" style="width:auto;" />
        </a>
        <p class="footer-about">{t('footer_about', lang)}</p>
        <div style="display:flex;flex-wrap:wrap;gap:7px;">
          {certs[lang].slice(0,4).map(c => (
            <span class="market-tag">{c}</span>
          ))}
        </div>
      </div>

      <!-- Explore -->
      <div>
        <h5>{t('footer_explore', lang)}</h5>
        <div class="footer-links">
          <a href="/">{t('nav_home', lang)}</a>
          <a href="/catalogo">{t('nav_catalog', lang)}</a>
          <a href="/nosotros">{t('nav_about', lang)}</a>
          <a href="/exportacion">{t('nav_export', lang)}</a>
          <a href="/contacto">{t('nav_contact', lang)}</a>
        </div>
      </div>

      <!-- Products / Categories -->
      <div>
        <h5>{t('footer_company', lang)}</h5>
        <div class="footer-links">
          <a href="/catalogo?categoria=pota">{lang === 'es' ? 'Pota' : lang === 'zh' ? '巨型鱿鱼' : 'Giant Squid'}</a>
          <a href="/catalogo?categoria=calamar">{lang === 'es' ? 'Calamar' : lang === 'zh' ? '鱿鱼和墨鱼' : 'Squid & Cuttlefish'}</a>
          <a href="/catalogo?categoria=pescado">{lang === 'es' ? 'Pescados' : lang === 'zh' ? '鱼类' : 'Fish'}</a>
          <a href="/catalogo?categoria=marisco">{lang === 'es' ? 'Mariscos' : lang === 'zh' ? '贝类海鲜' : 'Shellfish'}</a>
          <a href="/catalogo?categoria=ovas">{lang === 'es' ? 'Ovas' : lang === 'zh' ? '鱼卵' : 'Roe'}</a>
          <a href="/catalogo?categoria=preparados">{lang === 'es' ? 'Preparados' : lang === 'zh' ? '加工产品' : 'Value-Added'}</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h5>{t('footer_contact', lang)}</h5>
        <a class="footer-contact-item" href="mailto:pycmarperu@gmail.com">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-10 7L2 7"/>
          </svg>
          pycmarperu@gmail.com
        </a>
        <a class="footer-contact-item" href="tel:+51987486981">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.64A2 2 0 012 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          +51 987 486 981
        </a>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Castilla · Piura · Perú
        </div>
        <a
          class="btn btn-wa btn-sm"
          style="margin-top:12px;"
          href="https://wa.me/51987486981"
          target="_blank"
          rel="noopener"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

    </div>

    <div class="footer-legal">
      <a href="/privacidad">{t('legal_privacy', lang)}</a>
      <a href="/envio">{t('legal_shipping', lang)}</a>
      <a href="/terminos">{t('legal_terms', lang)}</a>
      <a href="/reclamaciones">{t('legal_claims', lang)}</a>
      <a href="/zonas-despacho">{t('legal_zones', lang)}</a>
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Pycmar Export Perú. {t('footer_rights', lang)}</span>
      <div class="socials">
        <a href="https://www.instagram.com/pycmarperu/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/profile.php?id=61583659807338" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </a>
        <a href="https://www.tiktok.com/@pycmarperu" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 20px;
    padding: 18px 0;
    border-top: 1px solid rgba(255,255,255,.1);
    margin-top: 0;
  }
  .footer-legal a {
    font-size: .78rem;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .15s;
  }
  .footer-legal a:hover { color: var(--teal); }
  @media(max-width:900px) {
    .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 32px; }
  }
  @media(max-width:560px) {
    .footer-grid { grid-template-columns: 1fr !important; }
    .footer-legal { gap: 6px 14px; }
  }
</style>
