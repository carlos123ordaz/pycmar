---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/CartDrawer.tsx';
import '../styles/global.css';
import type { Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'PYCMAR — Exportadores de Productos del Mar',
  description = 'Exportadores peruanos de productos del mar congelados de alta calidad. Pota, calamar, pescado, mariscos y más.',
  currentPath = Astro.url.pathname,
  ogImage = '/og-image.png',
  noIndex = false,
} = Astro.props;

const lang: Lang = Astro.locals.lang ?? 'es';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? Astro.url.origin;
const canonicalUrl = `${siteUrl}${currentPath}`;
const fullOgImage  = `${siteUrl}${ogImage}`;

const ogLocale = lang === 'zh' ? 'zh_CN' : lang === 'en' ? 'en_US' : 'es_PE';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Pycmar',
  description: 'Exportadores peruanos de productos del mar congelados de alta calidad.',
  url: siteUrl,
  logo: `${siteUrl}/logo.png`,
  image: fullOgImage,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+51-987-486-981',
    contactType: 'customer service',
    availableLanguage: ['Spanish', 'English', 'Chinese'],
  },
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'PE',
  },
  sameAs: [],
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0B1F3B" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={fullOgImage} />
  <meta property="og:image:alt"   content="Pycmar — Productos del Mar" />
  <meta property="og:site_name"   content="Pycmar" />
  <meta property="og:locale"      content={ogLocale} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={fullOgImage} />

  <!-- Favicons -->
  <link rel="icon"             type="image/x-icon" href="/favicon.ico" />
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon"             type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest"         href="/site.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <slot name="head" />
</head>
<body>
  <Header currentPath={currentPath} lang={lang} />

  <CartDrawer client:load lang={lang} />

  <slot />

  <Footer lang={lang} />

  <!-- WhatsApp FAB -->
  <a
    href="https://wa.me/51987486981?text=Hola%2C%20me%20interesa%20conocer%20m%C3%A1s%20sobre%20sus%20productos"
    class="wa-fab"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="WhatsApp"
    style="position:fixed;bottom:26px;right:26px;z-index:80;width:56px;height:56px;border-radius:50%;background:#25D366;color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 22px rgba(37,211,102,.45);transition:.22s;"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Toast container -->
  <div id="toast-container" style="position:fixed;bottom:96px;right:24px;z-index:200;display:flex;flex-direction:column;gap:8px;pointer-events:none;"></div>

  <script>
    (window as any).showToast = function(msg: string) {
      const el = document.createElement('div');
      el.style.cssText = 'background:var(--navy);color:#fff;padding:.75em 1.2em;border-radius:10px;font-size:.9rem;font-weight:600;box-shadow:0 6px 22px rgba(11,31,59,.3);animation:riseUp .3s ease both;pointer-events:auto;';
      el.textContent = '✓ ' + msg;
      document.getElementById('toast-container')?.appendChild(el);
      setTimeout(() => el.remove(), 2600);
    };

    const hdr = document.querySelector('.header') as HTMLElement;
    if (hdr) {
      window.addEventListener('scroll', () => {
        hdr.classList.toggle('scrolled', window.scrollY > 8);
      }, { passive: true });
    }
  </script>
</body>
</html>
