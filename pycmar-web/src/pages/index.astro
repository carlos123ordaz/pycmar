---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { createSupabaseServer, getImageUrl } from '../lib/supabase';
import { t, markets, certs, pName, catName, catDesc } from '../lib/i18n';
import type { Product, Category } from '../lib/types';

const lang = Astro.locals.lang;
const supabase = createSupabaseServer(Astro.cookies);

const [{ data: featuredData }, { data: categoriesData }, { data: countData }] = await Promise.all([
  supabase.from('products').select('*, images:product_images(*), category:categories(name_es,name_en,slug)')
    .eq('featured', true).eq('active', true).order('name_es').limit(8),
  supabase.from('categories').select('*').order('order_index'),
  supabase.from('products').select('category_id').eq('active', true),
]);

const featured: Product[] = featuredData ?? [];
const cats: Category[] = categoriesData ?? [];

// Product count per category
const productCounts = (countData ?? []).reduce((acc: Record<string, number>, p: any) => {
  acc[p.category_id] = (acc[p.category_id] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

// Prototype order: pota(0/span2), marisco(3), pescado(2), calamar(1), preparados(5) — skip ovas(4)
const catOrder = ['pota','marisco','pescado','calamar','preparados'];
const homeCats = catOrder.map(slug => cats.find(c => c.slug === slug)).filter(Boolean) as Category[];
const displayCats = homeCats.length > 0 ? homeCats : cats.slice(0, 5);

const title = lang === 'es' ? 'PYCMAR EXPORT PERU S.A.C. - Exportación de Productos Hidrobiológicos'
  : lang === 'en' ? 'PYCMAR EXPORT PERU S.A.C. - Hydrobiological Products Export'
  : 'PYCMAR EXPORT PERU S.A.C. - 水产品出口';
---

<BaseLayout title={title}>

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline preload="auto">
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>
    <div class="wrap">
      <div class="hero-copy fade-up">
        <span class="eyebrow on-dark">{t('hero_eyebrow', lang)}</span>
        <h1 class="display">
          {t('hero_title_1', lang)} <em>{t('hero_title_em', lang)}</em>{t('hero_title_2', lang)}
        </h1>
        <p class="lead">{t('hero_sub', lang)}</p>
        <div class="hero-cta">
          <a href="/catalogo" class="btn btn-accent btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            {t('cta_catalog', lang)}
          </a>
          <a href="/contacto" class="btn btn-ghost-light btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            {t('cta_quote', lang)}
          </a>
        </div>
        <div class="hero-stats">
          {[['35+', t('stat_species', lang)], ['6', t('stat_markets', lang)], ['−18°C', t('stat_cold', lang)], ['100%', t('stat_years', lang)]].map(([n, l]) => (
            <div class="hero-stat">
              <div class="n">{n}</div>
              <div class="l">{l}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Marquee / certs bar -->
    <div class="wrap">
      <div class="hero-marquee">
        <span><b>{t('certifications', lang)}:</b></span>
        {certs[lang].map((c, i) => (
          <>
            <span>{c}</span>
            {i < certs[lang].length - 1 && <span class="sep">›</span>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CATEGORIES ────────────────────────────────────────────────── -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">{t('cats_title', lang)}</span>
        <h2 class="h2" style="margin-top:14px;">{t('cats_heading', lang)}</h2>
        <p>{t('cats_sub', lang)}</p>
      </div>

      <div class="cat-grid">
        {displayCats.map((cat, idx) => {
          const count = productCounts[cat.id] ?? 0;
          const countLabel = lang === 'zh' ? `${count} 个产品` : lang === 'en' ? `${count} products` : `${count} productos`;
          return (
            <a
              href={`/catalogo?categoria=${cat.slug}`}
              class:list={['cat-card', { span2: idx === 0 }]}
              style="text-decoration:none;"
            >
              {cat.image_url
                ? <img src={getImageUrl('category-images', cat.image_url)} alt={catName(cat, lang)} />
                : <div class="ph" style="position:absolute;inset:0;z-index:-2;border-radius:0;"></div>
              }
              <div class="body">
                <div class="count">{countLabel}</div>
                <h3 style={idx === 0 ? 'font-size:1.9rem;' : ''}>{catName(cat, lang)}</h3>
                <div class="d">{catDesc(cat, lang)}</div>
                <div class="go">
                  {lang === 'zh' ? '探索' : lang === 'en' ? 'Explore' : 'Explorar'}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div style="margin-top:30px;text-align:center;">
        <a href="/catalogo" class="btn btn-outline btn-lg">
          {t('cats_all', lang)}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── BENEFITS ──────────────────────────────────────────────────── -->
  <section class="section bene">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">{t('benefits_title', lang)}</span>
        <h2 class="h2" style="margin-top:14px;">{t('benefits_heading', lang)}</h2>
        <p>{t('benefits_sub', lang)}</p>
      </div>
      <div class="bene-grid">
        {[
          { n:'01', icon:'shield', tk:'ben1_t', dk:'ben1_d' },
          { n:'02', icon:'snow',   tk:'ben2_t', dk:'ben2_d' },
          { n:'03', icon:'ship',   tk:'ben3_t', dk:'ben3_d' },
          { n:'04', icon:'leaf',   tk:'ben4_t', dk:'ben4_d' },
        ].map(({ n, icon, tk, dk }) => (
          <div class="bene-card">
            <span class="bene-n">{n}</span>
            <div class="bene-ic">
              {icon === 'shield' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {icon === 'snow'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 7l-5 5-5-5M17 17l-5-5-5 5"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M7 7l5 5 5-5M7 17l5-5 5 5"/></svg>}
              {icon === 'ship'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20a2.4 2.4 0 001.5.5 2.5 2.5 0 002.5-2.5A2.5 2.5 0 0011 18c0 .5-.1.9-.3 1.3"/><path d="M15 18a2.5 2.5 0 005 0"/><path d="M3 12l-1 4h18l-1-4H3z"/><path d="M6 12V8l4-4h4l4 4v4"/></svg>}
              {icon === 'leaf'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0118 13V7a3 3 0 00-3-3H7a7 7 0 000 14z"/><path d="M11 20v-7M8 13h6"/></svg>}
            </div>
            <h3>{t(tk, lang)}</h3>
            <p>{t(dk, lang)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FEATURED PRODUCTS ─────────────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="catalog-bar" style="margin-bottom:34px;">
          <div>
            <span class="eyebrow" style="display:block;margin-bottom:10px;">{t('featured_title', lang)}</span>
            <h2 class="h2">{t('featured_heading', lang)}</h2>
          </div>
          <a href="/catalogo" class="btn btn-outline">
            {t('cats_all', lang)}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="prod-grid">
          {featured.map(p => <ProductCard product={p} lang={lang} />)}
        </div>
      </div>
    </section>
  )}

  <!-- ── TRUST / CERTS ─────────────────────────────────────────────── -->
  <section class="section trust">
    <div class="wrap">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,72px);align-items:center;" class="trust-grid">
        <div>
          <span class="eyebrow">{t('trust_title', lang)}</span>
          <h2 class="h2" style="margin:14px 0 16px;">{t('trust_heading', lang)}</h2>
          <p class="lead">{t('trust_sub', lang)}</p>
          <div class="market-row">
            <span style="font-size:.82rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#7ef0c4;width:100%;margin-bottom:4px;">
              {t('markets_label', lang)}
            </span>
            {markets[lang].map(m => <span class="market-tag">{m}</span>)}
          </div>
        </div>
        <div class="cert-row" style="margin:0;">
          {certs[lang].map(c => (
            <div class="cert">
              <div class="ck">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span>{c}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ──────────────────────────────────────────────────── -->
  <section class="section-tight">
    <div class="wrap">
      <div class="cta-band">
        <div>
          <div class="divider-chev">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          </div>
          <h2 class="h2" style="margin-top:14px;">{t('cta_band_title', lang)}</h2>
          <p>{t('cta_band_sub', lang)}</p>
        </div>
        <div class="acts">
          <a href="/contacto" class="btn btn-accent btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            {t('cta_quote', lang)}
          </a>
          <a href="https://wa.me/51987486981" target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media(max-width:900px) {
    .hero-grid { grid-template-columns: 1fr !important; }
    .hero-visual { display: none; }
    .bene-grid { grid-template-columns: repeat(2,1fr) !important; }
    .trust-grid { grid-template-columns: 1fr !important; }
  }
  @media(max-width:640px) {
    .cat-grid { grid-template-columns: 1fr 1fr !important; }
    .cat-card.span2 { grid-column: span 2; }
    .prod-grid { grid-template-columns: repeat(2,1fr) !important; }
    .bene-grid { grid-template-columns: 1fr !important; }
  }
</style>
