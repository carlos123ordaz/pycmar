---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { createSupabaseServer, getImageUrl } from '../lib/supabase';
import { t, markets, certs, catName } from '../lib/i18n';
import type { Product, Category } from '../lib/types';

const lang = Astro.locals.lang;
const supabase = createSupabaseServer(Astro.cookies);

const [{ data: allProductsData }, { data: categoriesData }] = await Promise.all([
  supabase.from('products')
    .select('*, images:product_images(*), category:categories(name_es,name_en,name_zh,slug)')
    .eq('active', true)
    .order('featured', { ascending: false }),
  supabase.from('categories').select('*').order('order_index'),
]);

const cats: Category[] = categoriesData ?? [];
const allProducts: Product[] = allProductsData ?? [];

// Map category slug → image URL
const catImageMap: Record<string, string> = {};
for (const c of cats) {
  if (c.image_url) catImageMap[c.slug] = getImageUrl('category-images', c.image_url);
}

// Product count per category (for filter chips)
const countByCat: Record<string, number> = {};
for (const p of allProducts) {
  const slug = (p.category as any)?.slug ?? '';
  if (slug) countByCat[slug] = (countByCat[slug] || 0) + 1;
}

// Hero slides — 3 featured categories with curated images
const heroSlides = [
  {
    cat: 'pota',
    heroImg: '/hero/hero-pota.jpg',
    kicker: lang === 'es' ? 'Línea estrella' : lang === 'en' ? 'Flagship line' : '明星产品',
    title:  lang === 'es' ? 'Pota del Pacífico' : lang === 'en' ? 'Pacific Giant Squid' : '太平洋巨型鱿鱼',
    sub:    lang === 'es' ? 'Botones, anillas, filetes y rabas.' : lang === 'en' ? 'Buttons, rings, fillets and sticks.' : '按钮、环形、鱼片和鱼条。',
    cta:    lang === 'es' ? 'Ver pota' : lang === 'en' ? 'View squid' : '查看',
  },
  {
    cat: 'marisco',
    heroImg: '/hero/hero-mariscos.jpg',
    kicker: lang === 'es' ? 'Selección premium' : lang === 'en' ? 'Premium selection' : '精选产品',
    title:  lang === 'es' ? 'Mariscos del norte' : lang === 'en' ? 'Northern shellfish' : '北部贝类',
    sub:    lang === 'es' ? 'Concha de abanico, pulpo y langosta.' : lang === 'en' ? 'Scallops, octopus and lobster.' : '扇贝、章鱼和龙虾。',
    cta:    lang === 'es' ? 'Ver mariscos' : lang === 'en' ? 'View shellfish' : '查看',
  },
  {
    cat: 'pescado',
    heroImg: '/hero/hero-pescados.jpg',
    kicker: lang === 'es' ? 'Pesca del día' : lang === 'en' ? 'Catch of the day' : '当日捕鱼',
    title:  lang === 'es' ? 'Pescados congelados' : lang === 'en' ? 'Frozen fish' : '冷冻鱼类',
    sub:    lang === 'es' ? 'Perico, merluza, bonito y más.' : lang === 'en' ? 'Mahi, hake, bonito and more.' : '鲯鳅、无须鳕等。',
    cta:    lang === 'es' ? 'Ver pescados' : lang === 'en' ? 'View fish' : '查看',
  },
];

const certsList = certs[lang];
const coldLabel = lang === 'es' ? 'cadena de frío' : lang === 'en' ? 'cold chain' : '冷链';
const allLabel  = lang === 'es' ? 'Todos' : lang === 'en' ? 'All' : '全部';

const title = lang === 'es' ? 'PYCMAR EXPORT PERU S.A.C. - Exportación de Productos Hidrobiológicos'
  : lang === 'en' ? 'PYCMAR EXPORT PERU S.A.C. - Hydrobiological Products Export'
  : 'PYCMAR EXPORT PERU S.A.C. - 水产品出口';
---

<BaseLayout title={title}>

  <!-- ══ HERO SLIDER ══════════════════════════════════════════════════════ -->
  <section class="heroF" id="heroF">
    <div class="heroF-slides" id="heroF-slides">
      {heroSlides.map((slide, idx) => (
          <div class="heroF-slide">
            <img
              class="heroF-bg"
              src={slide.heroImg}
              alt={slide.title}
              loading={idx === 0 ? 'eager' : 'lazy'}
            />
            <span class="heroF-scrim" />
            <div class="wrap heroF-inner">
              <div class="heroF-copy">
                <span class="heroF-kicker">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 18l6-6-6-6"/></svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 18l6-6-6-6"/></svg>
                  {slide.kicker}
                </span>
                <h1 class="heroF-title">{slide.title}</h1>
                <p class="heroF-sub">{slide.sub}</p>
                <button class="btn btn-accent btn-lg heroF-cta" data-cat={slide.cat}>
                  {slide.cta}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </div>
            </div>
          </div>
        ))}
    </div>

    <button class="heroF-arrow heroF-left" id="heroF-prev" aria-label="anterior">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button class="heroF-arrow heroF-right" id="heroF-next" aria-label="siguiente">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>

    <div class="heroF-dots" id="heroF-dots">
      {heroSlides.map((_, k) => (
        <button class={`heroF-dot${k === 0 ? ' on' : ''}`} aria-label={`slide ${k + 1}`} data-slide={k} />
      ))}
    </div>

    <div class="heroF-badge">
      <b>−18°C</b>
      <span>{coldLabel}</span>
    </div>

    <!-- Cert strip — inside hero so queda dentro del 100vh -->
    <div class="heroF-certs">
      <div class="heroF-progress-bar" id="heroF-progress-bar" aria-hidden="true"></div>
      <span class="heroF-certs-lbl">{t('certifications', lang)}</span>
      {certsList.map((c, k) => (
        <Fragment>
          {k > 0 && (
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="opacity:.4;flex:none;color:var(--accent)"><path d="M9 18l6-6-6-6"/></svg>
          )}
          <span class="heroF-certs-item">{c}</span>
        </Fragment>
      ))}
    </div>
  </section>

  <!-- ══ STATS STRIP ══════════════════════════════════════════════════════ -->
  <div class="wrap">
    <div class="stats-strip reveal">
      <div class="stat-item">
        <div class="stat-num"><span class="stat-count" data-target={allProducts.length}>0</span><span class="stat-suf">+</span></div>
        <div class="stat-lbl">{lang === 'es' ? 'Productos' : lang === 'en' ? 'Products' : '产品'}</div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-num"><span class="stat-count" data-target={certsList.length}>0</span></div>
        <div class="stat-lbl">{lang === 'es' ? 'Certificaciones' : lang === 'en' ? 'Certifications' : '认证'}</div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-num"><span class="stat-count" data-target={markets[lang].length}>0</span></div>
        <div class="stat-lbl">{lang === 'es' ? 'Mercados' : lang === 'en' ? 'Markets' : '市场'}</div>
      </div>
      <div class="stat-sep" aria-hidden="true"></div>
      <div class="stat-item">
        <div class="stat-num"><span class="stat-count" data-target={cats.length}>0</span></div>
        <div class="stat-lbl">{lang === 'es' ? 'Categorías' : lang === 'en' ? 'Categories' : '品类'}</div>
      </div>
    </div>
  </div>

  <!-- ══ CATÁLOGO + FILTROS ════════════════════════════════════════════════ -->
  <section class="section-tight" id="productos">
    <div class="wrap">

      <div class="shop-head reveal">
        <div>
          <span class="eyebrow" style="display:block;margin-bottom:10px;">{t('featured_title', lang)}</span>
          <h2 class="h2">{t('featured_heading', lang)}</h2>
        </div>
        <span class="shop-count">
          <b id="prod-count">{allProducts.length}</b> {t('catalog_count', lang)}
        </span>
      </div>

      <!-- Category filter chips -->
      <div class="catfilter" id="catfilter">
        <button class="catfilter-chip on" data-cat="all">
          <span class="catfilter-ic">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </span>
          <span class="catfilter-lbl">{allLabel}</span>
          <span class="catfilter-ct">{allProducts.length}</span>
        </button>
        {cats.map(cat => {
          const count = countByCat[cat.slug] ?? 0;
          if (count === 0) return null;
          return (
            <button class="catfilter-chip" data-cat={cat.slug}>
              <span class="catfilter-ic">
                {cat.image_url
                  ? <img src={catImageMap[cat.slug]} alt={catName(cat, lang)} style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                  : <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 8v4M12 16h.01"/></svg>
                }
              </span>
              <span class="catfilter-lbl">{catName(cat, lang)}</span>
              <span class="catfilter-ct">{count}</span>
            </button>
          );
        })}
      </div>

      <!-- Products grid -->
      {allProducts.length === 0 ? (
        <div class="center" style="padding:60px 0;color:var(--gray);">
          <p>{t('no_results', lang)}</p>
        </div>
      ) : (
        <div class="prod-grid home-grid" id="prod-grid">
          {allProducts.map((p, idx) => (
            <div class={`prod-item${idx >= 8 ? ' hidden' : ''}`} data-cat={(p.category as any)?.slug ?? ''} data-idx={idx}>
              <ProductCard product={p} lang={lang} />
            </div>
          ))}
        </div>
      )}

      <div class="center" style="margin-top:44px;" id="ver-mas-wrap">
        <button id="ver-mas-btn" class="btn btn-outline btn-lg">
          {lang === 'es' ? 'Ver más' : lang === 'en' ? 'See more' : '查看更多'}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </button>
      </div>

    </div>
  </section>

  <!-- ══ BENEFICIOS ═══════════════════════════════════════════════════════ -->
  <section class="section bene">
    <div class="wrap">
      <div class="sec-head center">
        <span class="eyebrow">{t('benefits_title', lang)}</span>
        <h2 class="h2" style="margin-top:14px;">{t('benefits_heading', lang)}</h2>
        <p>{t('benefits_sub', lang)}</p>
      </div>
      <div class="bene-grid">
        {[
          { n:'01', icon:'shield', tk:'ben1_t', dk:'ben1_d' },
          { n:'02', icon:'snow',   tk:'ben2_t', dk:'ben2_d' },
          { n:'03', icon:'ship',   tk:'ben3_t', dk:'ben3_d' },
          { n:'04', icon:'leaf',   tk:'ben4_t', dk:'ben4_d' },
        ].map(({ n, icon, tk, dk }, i) => (
          <div class={`bene-card reveal reveal-d${i}`}>
            <span class="bene-n">{n}</span>
            <div class="bene-ic">
              {icon === 'shield' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {icon === 'snow'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 7l-5 5-5-5M17 17l-5-5-5 5"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M7 7l5 5 5-5M7 17l5-5 5 5"/></svg>}
              {icon === 'ship'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20a2.4 2.4 0 001.5.5 2.5 2.5 0 002.5-2.5A2.5 2.5 0 0011 18c0 .5-.1.9-.3 1.3"/><path d="M15 18a2.5 2.5 0 005 0"/><path d="M3 12l-1 4h18l-1-4H3z"/><path d="M6 12V8l4-4h4l4 4v4"/></svg>}
              {icon === 'leaf'   && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0118 13V7a3 3 0 00-3-3H7a7 7 0 000 14z"/><path d="M11 20v-7M8 13h6"/></svg>}
            </div>
            <h3>{t(tk, lang)}</h3>
            <p>{t(dk, lang)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ CONFIANZA / CERTIFICACIONES ══════════════════════════════════════ -->
  <section class="section trust">
    <div class="wrap">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,72px);align-items:center;" class="trust-grid">
        <div class="reveal r-left">
          <span class="eyebrow">{t('trust_title', lang)}</span>
          <h2 class="h2" style="margin:14px 0 16px;">{t('trust_heading', lang)}</h2>
          <p class="lead">{t('trust_sub', lang)}</p>
          <div class="market-row">
            <span style="font-size:.82rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#7ef0c4;width:100%;margin-bottom:4px;">
              {t('markets_label', lang)}
            </span>
            {markets[lang].map(m => <span class="market-tag">{m}</span>)}
          </div>
        </div>
        <div class="cert-row reveal r-right" style="margin:0;">
          {certs[lang].map(c => (
            <div class="cert">
              <div class="ck">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span>{c}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BANDA CTA ════════════════════════════════════════════════════════ -->
  <section class="section-tight">
    <div class="wrap">
      <div class="cta-band">
        <div class="reveal">
          <div class="divider-chev">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          </div>
          <h2 class="h2" style="margin-top:14px;">{t('cta_band_title', lang)}</h2>
          <p>{t('cta_band_sub', lang)}</p>
        </div>
        <div class="acts reveal reveal-d1">
          <a href="/contacto" class="btn btn-accent btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            {t('cta_quote', lang)}
          </a>
          <a href="https://wa.me/51987486981" target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ══ HERO SLIDER (heroF) ═════════════════════════════════════════════════ */
  .heroF {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--navy);
    /* JS sobreescribe con el alto exacto disponible bajo el header */
    height: calc(100vh - var(--header-h));
    min-height: 480px;
  }
  .heroF-slides {
    display: flex;
    height: 100%;
    transition: transform .65s cubic-bezier(.22,.61,.36,1);
  }
  .heroF-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
  }
  .heroF-bg {
    position: absolute;
    top: -15%;
    left: 0;
    right: 0;
    width: 100%;
    height: 130%; /* extra para el parallax scroll */
    object-fit: cover;
    z-index: 0;
    will-change: transform;
  }
  .heroF-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(8,22,42,.88) 0%,
      rgba(8,22,42,.65) 38%,
      rgba(8,22,42,.18) 70%,
      rgba(8,22,42,0) 100%
    );
  }
  .heroF-inner {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .heroF-copy {
    max-width: 36rem;
    color: #fff;
  }
  .heroF-kicker {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: .8rem;
    font-weight: 800;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .heroF-kicker svg { opacity: .8; }
  .heroF-title {
    font-size: clamp(2.2rem, 4.8vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -.035em;
    line-height: 1.04;
    color: #fff;
    margin: 14px 0 0;
    text-shadow: 0 2px 24px rgba(0,0,0,.35);
  }
  .heroF-sub {
    font-size: clamp(1rem, 1.55vw, 1.28rem);
    line-height: 1.5;
    color: #d4e2f2;
    margin: 18px 0 28px;
    max-width: 34ch;
  }

  /* Arrows */
  .heroF-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,.35);
    background: rgba(8,22,42,.4);
    backdrop-filter: blur(6px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: .2s var(--ease);
  }
  .heroF-arrow:hover {
    background: var(--accent);
    color: #052e2e;
    border-color: var(--accent);
  }
  .heroF-left  { left:  clamp(14px, 2.5vw, 40px); }
  .heroF-right { right: clamp(14px, 2.5vw, 40px); }

  /* Dots */
  .heroF-dots {
    position: absolute;
    bottom: 72px;
    left: 0;
    right: 0;
    z-index: 5;
    display: flex;
    justify-content: center;
    gap: 10px;
  }
  .heroF-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.4);
    transition: .25s var(--ease);
    padding: 0;
    cursor: pointer;
  }
  .heroF-dot.on {
    background: var(--accent);
    width: 30px;
    border-radius: 5px;
  }

  /* Badge −18°C */
  @keyframes badge-pulse {
    0%   { box-shadow: var(--shadow-lg), 0 0 0 0   rgba(126,240,196,.6); }
    65%  { box-shadow: var(--shadow-lg), 0 0 0 18px rgba(126,240,196,0); }
    100% { box-shadow: var(--shadow-lg), 0 0 0 0   rgba(126,240,196,0); }
  }
  .heroF-badge {
    position: absolute;
    right: clamp(16px, 3vw, 48px);
    top: clamp(20px, 3vw, 40px);
    z-index: 5;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--accent);
    color: #052e2e;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    transform: rotate(-7deg);
    animation: badge-pulse 2.8s ease-out infinite;
  }
  .heroF-badge b   { font-size: 1.28rem; font-weight: 800; letter-spacing: -.03em; }
  .heroF-badge span { font-size: .59rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; text-align: center; line-height: 1.1; margin-top: 2px; }

  @media(max-width: 680px) {
    .heroF { min-height: 480px; } /* JS maneja el alto exacto en móvil también */
    .heroF-scrim { background: linear-gradient(to top, rgba(8,22,42,.9) 0%, rgba(8,22,42,.5) 45%, rgba(8,22,42,.2) 100%); }
    .heroF-inner { align-items: flex-end; padding-bottom: 120px; }
    .heroF-badge { width: 74px; height: 74px; }
    .heroF-badge b { font-size: 1rem; }
    .heroF-arrow { width: 42px; height: 42px; }
    .heroF-certs { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; }
    .heroF-certs::-webkit-scrollbar { display: none; }
  }

  /* ══ PROGRESS BAR (top of cert strip) ══════════════════════════════════ */
  @keyframes progressFill {
    from { width: 0%; }
    to   { width: 100%; }
  }
  .heroF-progress-bar {
    position: absolute;
    top: 0; left: 0;
    height: 2px;
    width: 0%;
    background: var(--accent);
    z-index: 10;
    border-radius: 0 2px 2px 0;
    pointer-events: none;
  }

  /* ══ CERT STRIP (dentro del hero) ═══════════════════════════════════════ */
  .heroF-certs {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 18px;
    padding: 14px clamp(16px, 4vw, 60px);
    background: rgba(5, 15, 30, .72);
    backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,.1);
  }
  .heroF-certs-lbl {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
    margin-right: 4px;
  }
  .heroF-certs-item {
    font-size: .88rem;
    font-weight: 600;
    color: rgba(255,255,255,.82);
    white-space: nowrap;
  }

  /* ══ STATS STRIP ════════════════════════════════════════════════════════ */
  .stats-strip {
    display: flex;
    align-items: center;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }
  .stat-item {
    flex: 1;
    text-align: center;
    padding: 0 8px;
  }
  .stat-num {
    font-size: clamp(2rem, 3.8vw, 2.8rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
    letter-spacing: -.04em;
  }
  .stat-suf { font-size: .65em; color: var(--accent-600); vertical-align: super; }
  .stat-lbl {
    font-size: .74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--gray);
    margin-top: 7px;
  }
  .stat-sep {
    width: 1px;
    height: 38px;
    background: var(--line-2);
    flex: none;
  }
  @media(max-width: 520px) {
    .stats-strip { padding: 20px 0; }
    .stat-lbl { font-size: .65rem; letter-spacing: .06em; }
  }

  /* ══ SHOP HEAD ══════════════════════════════════════════════════════════ */
  .shop-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .shop-count { font-size: .95rem; color: var(--gray); }
  .shop-count b { color: var(--navy); font-weight: 800; font-size: 1.1rem; }

  /* ══ CATEGORY FILTER CHIPS ══════════════════════════════════════════════ */
  .catfilter {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }
  .catfilter-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px 10px 10px;
    border-radius: 999px;
    border: 1.5px solid var(--line-2);
    background: #fff;
    color: var(--navy);
    cursor: pointer;
    transition: .2s var(--ease);
    font-family: inherit;
  }
  .catfilter-chip:hover {
    border-color: var(--navy);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .catfilter-ic {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--mist);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    overflow: hidden;
    flex: none;
    transition: .2s;
  }
  .catfilter-ic svg { width: 19px; height: 19px; }
  .catfilter-lbl {
    font-size: .97rem;
    font-weight: 700;
    letter-spacing: -.01em;
  }
  .catfilter-ct {
    font-size: .74rem;
    font-weight: 700;
    color: var(--gray-2);
    background: var(--mist);
    border-radius: 999px;
    padding: 2px 8px;
    min-width: 22px;
    text-align: center;
  }
  .catfilter-chip.on {
    background: var(--navy);
    border-color: var(--navy);
    color: #fff;
  }
  .catfilter-chip.on .catfilter-ic { background: var(--accent); color: #052e2e; }
  .catfilter-chip.on .catfilter-ct { background: rgba(255,255,255,.16); color: #fff; }

  @media(max-width: 768px) {
    .catfilter {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 6px;
    }
    .catfilter::-webkit-scrollbar { display: none; }
    .catfilter-chip { flex-shrink: 0; }
  }
  @media(max-width: 520px) {
    .catfilter-chip { padding: 8px 14px 8px 8px; gap: 8px; }
    .catfilter-ic   { width: 30px; height: 30px; }
    .catfilter-ic svg { width: 16px; height: 16px; }
    .catfilter-lbl  { font-size: .88rem; }
  }

  /* ══ PRODUCT GRID (home) ════════════════════════════════════════════════ */
  .home-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  .prod-item { display: contents; }
  .prod-item.hidden { display: none; }

  @media(max-width: 1100px) { .home-grid { grid-template-columns: repeat(3, 1fr); } }
  @media(max-width: 680px)  { .home-grid { grid-template-columns: repeat(2, 1fr); } }

  /* ══ RESPONSIVE trust ════════════════════════════════════════════════════ */
  @media(max-width: 900px) {
    .trust-grid { grid-template-columns: 1fr !important; }
    .bene-grid  { grid-template-columns: repeat(2,1fr) !important; }
  }
  @media(max-width: 640px) {
    .bene-grid { grid-template-columns: 1fr !important; }
  }

  /* Respeta preferencia de movimiento reducido */
  @media(prefers-reduced-motion: reduce) {
    .heroF-slides { transition: none; }
  }
</style>

<script>
  // ── Hero: altura exacta = viewport menos lo que ocupa encima del hero ────
  (function () {
    const hero = document.getElementById('heroF') as HTMLElement | null;
    if (!hero) return;
    function fitHero() {
      const top = hero!.getBoundingClientRect().top + window.scrollY; // offsetTop real
      const h = Math.max(480, window.innerHeight - top);
      hero!.style.height = h + 'px';
    }
    fitHero();
    window.addEventListener('resize', fitHero, { passive: true });
  })();

  // ── Hero slider + progress bar ────────────────────────────────────────────
  (function () {
    const track = document.getElementById('heroF-slides') as HTMLElement | null;
    const dotsEl = document.querySelectorAll<HTMLButtonElement>('#heroF-dots .heroF-dot');
    const progressBar = document.getElementById('heroF-progress-bar') as HTMLElement | null;
    const INTERVAL = 6500;
    const n = dotsEl.length;
    if (!track || n === 0) return;

    let cur = 0;
    let timer: ReturnType<typeof setInterval>;

    function resetProgress() {
      if (!progressBar) return;
      progressBar.style.animation = 'none';
      void progressBar.offsetWidth; // force reflow
      progressBar.style.animation = `progressFill ${INTERVAL}ms linear forwards`;
    }

    function go(idx: number) {
      cur = ((idx % n) + n) % n;
      track!.style.transform = `translateX(-${cur * 100}%)`;
      dotsEl.forEach((d, i) => d.classList.toggle('on', i === cur));
      resetProgress();
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => go(cur + 1), INTERVAL);
    }

    document.getElementById('heroF-prev')?.addEventListener('click', () => { go(cur - 1); startTimer(); });
    document.getElementById('heroF-next')?.addEventListener('click', () => { go(cur + 1); startTimer(); });
    dotsEl.forEach(d => d.addEventListener('click', () => { go(Number(d.dataset.slide)); startTimer(); }));

    startTimer();
    resetProgress(); // arrancar barra desde el inicio
  })();

  // ── Parallax hero ─────────────────────────────────────────────────────────
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const bgs = document.querySelectorAll<HTMLElement>('.heroF-bg');
    const hero = document.getElementById('heroF');
    if (!hero || bgs.length === 0) return;
    const heroTop = hero.getBoundingClientRect().top + window.scrollY;
    const heroH   = hero.offsetHeight;
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y > heroTop + heroH) return; // hero ya salió del viewport
      const shift = (y - heroTop) * 0.15;
      bgs.forEach(bg => { bg.style.transform = `translateY(${shift}px)`; });
    }, { passive: true });
  })();

  // ── Category filter + Ver más ────────────────────────────────────────────
  (function () {
    const chips = document.querySelectorAll<HTMLButtonElement>('#catfilter .catfilter-chip');
    const items = document.querySelectorAll<HTMLElement>('#prod-grid .prod-item');
    const countEl = document.getElementById('prod-count');
    const verMasWrap = document.getElementById('ver-mas-wrap');

    const LIMIT = 8;
    let showAll = false;
    let currentCat = 'all';

    function applyFilter(cat: string) {
      let visible = 0;
      items.forEach(item => {
        const catMatch = cat === 'all' || item.dataset.cat === cat;
        const idx = parseInt(item.dataset.idx ?? '0', 10);
        const withinLimit = cat !== 'all' || showAll || idx < LIMIT;
        const show = catMatch && withinLimit;
        item.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (countEl) countEl.textContent = String(visible);

      // Show "Ver más" only when viewing all and there are hidden items
      if (verMasWrap) {
        const hasMore = cat === 'all' && !showAll && items.length > LIMIT;
        verMasWrap.style.display = hasMore ? '' : 'none';
      }
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
        currentCat = chip.dataset.cat ?? 'all';
        applyFilter(currentCat);

        const grid = document.getElementById('prod-grid');
        if (grid) {
          const top = grid.getBoundingClientRect().top + window.scrollY - 100;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    document.getElementById('ver-mas-btn')?.addEventListener('click', () => {
      showAll = true;
      applyFilter(currentCat);
    });

    // Hero CTA buttons → filter by category and scroll to products
    document.querySelectorAll<HTMLButtonElement>('.heroF-cta').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.cat;
        if (!cat) return;
        const chip = document.querySelector<HTMLButtonElement>(`#catfilter .catfilter-chip[data-cat="${cat}"]`);
        if (chip) chip.click();
        else {
          const sec = document.getElementById('productos');
          if (sec) window.scrollTo({ top: sec.getBoundingClientRect().top + window.scrollY - 90, behavior: 'smooth' });
        }
      });
    });

    // Init
    applyFilter('all');
  })();

  // ── Contadores animados (stats strip) ────────────────────────────────────
  (function () {
    const counters = document.querySelectorAll<HTMLElement>('.stat-count');
    if (counters.length === 0) return;

    function animateCount(el: HTMLElement) {
      const target = parseInt(el.dataset.target ?? '0', 10);
      if (target === 0) { el.textContent = '0'; return; }
      const dur = 1300;
      const start = performance.now();
      function step(now: number) {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
        el.textContent = String(Math.floor(eased * target));
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = String(target);
      }
      requestAnimationFrame(step);
    }

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          animateCount(e.target as HTMLElement);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(c => obs.observe(c));
  })();
</script>
