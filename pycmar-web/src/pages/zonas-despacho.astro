---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n';

const lang = Astro.locals.lang;
const isEs = lang === 'es';
const isZh = lang === 'zh';

const title = isEs ? 'Zonas de Despacho — Pycmar' : isZh ? '配送区域 — Pycmar' : 'Delivery Zones — Pycmar';
const desc  = isEs
  ? 'Consulta las zonas de entrega de productos Pycmar en la región Piura, Perú.'
  : isZh
  ? '查看Pycmar产品在秘鲁皮乌拉地区的配送区域。'
  : 'Check Pycmar\'s product delivery zones in the Piura region, Peru.';

const zonas = [
  {
    es_n: 'Piura y Castilla',
    en_n: 'Piura and Castilla',
    zh_n: '皮乌拉和卡斯蒂利亚',
    distritos: ['Piura', 'Castilla', 'Veintiséis de Octubre'],
    plazo: '24–48 h',
    disponible: true,
  },
  {
    es_n: 'Catacaos y La Unión',
    en_n: 'Catacaos and La Unión',
    zh_n: '卡塔卡奥斯和拉乌尼翁',
    distritos: ['Catacaos', 'La Arena', 'La Unión', 'Cura Mori'],
    plazo: '48–72 h',
    disponible: true,
  },
  {
    es_n: 'Sullana y alrededores',
    en_n: 'Sullana and surroundings',
    zh_n: '苏亚纳及周边',
    distritos: ['Sullana', 'Bellavista', 'Querecotillo', 'Marcavelica'],
    plazo: '48–72 h',
    disponible: true,
  },
  {
    es_n: 'Paita',
    en_n: 'Paita',
    zh_n: '派塔',
    distritos: ['Paita', 'Amotape', 'Arenal', 'La Huaca'],
    plazo: '48–72 h',
    disponible: true,
  },
  {
    es_n: 'Talara',
    en_n: 'Talara',
    zh_n: '塔拉拉',
    distritos: ['Pariñas', 'El Alto', 'La Brea', 'Lobitos'],
    plazo: isEs ? 'Consultar' : isZh ? '请咨询' : 'Enquire',
    disponible: false,
  },
  {
    es_n: 'Sechura',
    en_n: 'Sechura',
    zh_n: '塞丘拉',
    distritos: ['Sechura', 'Bernal', 'Cristo Nos Valga', 'Rinconada Llicuar'],
    plazo: isEs ? 'Consultar' : isZh ? '请咨询' : 'Enquire',
    disponible: false,
  },
];

const infoMsg = isEs
  ? '¿No encuentras tu zona? Contáctanos por WhatsApp — coordinamos entregas a zonas no listadas para pedidos de volumen.'
  : isZh
  ? '找不到您的区域？请通过WhatsApp联系我们——我们可以为大量订单协调未列出区域的配送。'
  : "Can't find your zone? Contact us via WhatsApp — we coordinate deliveries to unlisted zones for bulk orders.";

const waMsg = isEs
  ? 'Consultar disponibilidad en mi zona'
  : isZh
  ? '查询我所在区域的配送'
  : 'Check availability in my zone';

const exportTitle = isEs ? 'Despachos de exportación' : isZh ? '出口发货' : 'Export Dispatch';
const exportText  = isEs
  ? 'Para pedidos de exportación (FCL / LCL), coordinamos el despacho desde el puerto de Paita hacia cualquier destino internacional. Consulta tiempos de tránsito en nuestra sección de <a href="/exportacion">Exportación</a>.'
  : isZh
  ? '对于出口订单（FCL / LCL），我们从派塔港协调发货至任何国际目的地。请查看我们的<a href="/exportacion">出口业务</a>页面了解运输时间。'
  : 'For export orders (FCL / LCL), we coordinate dispatch from the port of Paita to any international destination. Check transit times in our <a href="/exportacion">Export</a> section.';
---

<BaseLayout title={title} description={desc}>
  <main class="legal-page">
    <div class="wrap">
      <h1>{t('legal_zones', lang)}</h1>
      <p class="subtitle">
        {isEs ? 'Cobertura actual de entrega en la región Piura' : isZh ? '皮乌拉地区当前配送覆盖范围' : 'Current delivery coverage in the Piura region'}
      </p>

      <div class="info-box">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/>
        </svg>
        <p>{infoMsg}</p>
      </div>

      <div class="zonas-grid">
        {zonas.map(z => (
          <div class={`zona-card ${z.disponible ? '' : 'zona-pronto'}`}>
            <div class="zona-header">
              <span class="zona-nombre">{isEs ? z.es_n : isZh ? z.zh_n : z.en_n}</span>
              <span class={`zona-badge ${z.disponible ? 'badge-ok' : 'badge-consultar'}`}>
                {z.disponible ? t('legal_zone_available', lang) : t('legal_zone_consult', lang)}
              </span>
            </div>
            <ul class="zona-distritos">
              {z.distritos.map(d => <li>{d}</li>)}
            </ul>
            <div class="zona-plazo">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {t('legal_zone_time', lang)} <strong>{z.plazo}</strong>
            </div>
          </div>
        ))}
      </div>

      <div class="nota-exportacion">
        <h2>{exportTitle}</h2>
        <p set:html={exportText} />
      </div>

      <div class="cta-wa">
        <a href={`https://wa.me/51987486981?text=${encodeURIComponent(isEs ? 'Hola, quiero consultar si hacen despacho a mi zona' : isZh ? '您好，我想咨询您是否配送到我所在的区域' : 'Hello, I would like to check if you deliver to my zone')}`}
           target="_blank" rel="noopener" class="btn-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {waMsg}
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .legal-page { padding: 80px 0 100px; min-height: 60vh; }
  h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); color: var(--navy); margin-bottom: 6px; }
  .subtitle { color: var(--slate); font-size: .95rem; margin-bottom: 32px; }
  .info-box {
    display: flex; align-items: flex-start; gap: 12px;
    background: #EFF6FF; border-left: 4px solid var(--teal);
    padding: 14px 18px; border-radius: 0 8px 8px 0; margin-bottom: 40px;
    color: #1e3a5f; font-size: .93rem; line-height: 1.5;
  }
  .info-box svg { flex-shrink: 0; margin-top: 2px; }
  .info-box p { margin: 0; }
  .zonas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-bottom: 56px; }
  .zona-card { border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 20px; background: #fff; }
  .zona-pronto { opacity: .75; }
  .zona-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .zona-nombre { font-weight: 700; color: var(--navy); font-size: 1rem; }
  .zona-badge { font-size: .72rem; font-weight: 700; padding: 3px 10px; border-radius: 99px; }
  .badge-ok { background: #D1FAE5; color: #065F46; }
  .badge-consultar { background: #FEF3C7; color: #92400E; }
  .zona-distritos { list-style: none; padding: 0; margin: 0 0 14px; }
  .zona-distritos li { font-size: .88rem; color: #4B5563; padding: 3px 0; border-bottom: 1px solid #f3f4f6; }
  .zona-distritos li:last-child { border-bottom: none; }
  .zona-plazo { display: flex; align-items: center; gap: 6px; font-size: .83rem; color: var(--slate); margin-top: 4px; }
  .nota-exportacion { border-top: 1px solid #e5e7eb; padding-top: 40px; margin-bottom: 40px; }
  .nota-exportacion h2 { font-size: 1.15rem; color: var(--navy); margin-bottom: 10px; }
  .nota-exportacion p { color: #374151; line-height: 1.7; font-size: .96rem; }
  .nota-exportacion a { color: var(--teal); }
  .cta-wa { text-align: center; }
  .btn-wa {
    display: inline-flex; align-items: center; gap: 10px;
    background: #25D366; color: #fff; padding: 14px 28px;
    border-radius: 10px; font-weight: 700; font-size: .97rem;
    text-decoration: none; transition: opacity .15s;
  }
  .btn-wa:hover { opacity: .88; }
</style>
