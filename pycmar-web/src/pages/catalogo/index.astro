---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { createSupabaseServer, getImageUrl } from '../../lib/supabase';
import { t, catName } from '../../lib/i18n';
import type { Product, Category } from '../../lib/types';

const lang = Astro.locals.lang;
const supabase = createSupabaseServer(Astro.cookies);

const url = Astro.url;
const catParam  = url.searchParams.get('categoria') ?? '';
const qParam    = url.searchParams.get('q')         ?? '';
const sortParam = url.searchParams.get('orden')     ?? 'featured';

// Fetch categories
const { data: categoriesData } = await supabase
  .from('categories')
  .select('*')
  .order('order_index');

// Fetch all active products
let query = supabase
  .from('products')
  .select('*, images:product_images(*), category:categories(name_es,name_en,name_zh,slug)')
  .eq('active', true);

if (qParam) query = (query as any).or(`name_es.ilike.%${qParam}%,name_en.ilike.%${qParam}%,name_zh.ilike.%${qParam}%`);

if (sortParam === 'price_lo') query = (query as any).order('price', { ascending: true });
else if (sortParam === 'price_hi') query = (query as any).order('price', { ascending: false });
else if (sortParam === 'az') query = (query as any).order('name_es');
else query = (query as any).order('featured', { ascending: false });

const { data: productData } = await query;

let products: Product[] = productData ?? [];
if (catParam) products = products.filter(p => (p.category as any)?.slug === catParam);

const cats: Category[] = categoriesData ?? [];

function buildUrl(params: Record<string, string>) {
  const p = new URLSearchParams();
  if (params.categoria) p.set('categoria', params.categoria);
  if (params.q)         p.set('q', params.q);
  if (params.orden && params.orden !== 'featured') p.set('orden', params.orden);
  const qs = p.toString();
  return `/catalogo${qs ? '?' + qs : ''}`;
}

const currentParams = { categoria: catParam, q: qParam, orden: sortParam };

const catEmoji: Record<string, string> = {
  pota: '🦑', marisco: '🦐', pescado: '🐟',
  calamar: '🐙', preparados: '🥡', ovas: '🫧',
};

const pageTitle = lang === 'es' ? 'Catálogo — Pycmar'
  : lang === 'en' ? 'Catalog — Pycmar'
  : '产品目录 — Pycmar';
---

<BaseLayout title={pageTitle} currentPath="/catalogo">

  <!-- Page header -->
  <div class="catalog-head">
    <div class="wrap">
      <span class="eyebrow" style="display:block;margin-bottom:12px;">{t('nav_catalog', lang)}</span>
      <h1 class="h2">{t('catalog_title', lang)}</h1>
      <p class="lead" style="margin-top:10px;max-width:50ch;">{t('catalog_sub', lang)}</p>
    </div>
  </div>

  <!-- Category filter bar -->
  <div style="background:#fff;border-bottom:1px solid var(--line);position:sticky;top:var(--header-h);z-index:40;">
    <div class="wrap">
      <div class="cat-filter-scroll">
        <div class="cat-filter-bar">
          <a
            href={buildUrl({ ...currentParams, categoria: '' })}
            class:list={['cat-pill', { 'cat-pill-active': !catParam }]}
          >
            <span class="cat-pill-icon cat-pill-icon-svg">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
              </svg>
            </span>
            {t('all', lang)}
          </a>
          {cats.map(cat => (
            <a
              href={buildUrl({ ...currentParams, categoria: catParam === cat.slug ? '' : cat.slug })}
              class:list={['cat-pill', { 'cat-pill-active': catParam === cat.slug }]}
            >
              <span class="cat-pill-icon">
                {cat.image_url
                  ? <img src={getImageUrl('category-images', cat.image_url)} alt="" width="24" height="24" style="width:24px;height:24px;object-fit:cover;border-radius:50%;" />
                  : <span style="font-size:1rem;line-height:1;">{catEmoji[cat.slug] ?? '🐟'}</span>
                }
              </span>
              {catName(cat, lang)}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Products area -->
  <div class="wrap section-tight">

    <!-- Toolbar -->
    <div class="catalog-bar">
      <span class="ct"><b>{products.length}</b> {t('catalog_count', lang)}</span>
      <div class="row" style="gap:9px;">
        <span style="font-size:.88rem;color:var(--gray);font-weight:600;">{t('sort_label', lang)}</span>
        <form method="get" action="/catalogo" style="margin:0;">
          {catParam && <input type="hidden" name="categoria" value={catParam} />}
          {qParam   && <input type="hidden" name="q"         value={qParam} />}
          <select class="select" name="orden" onchange="this.form.submit()">
            <option value="featured" selected={sortParam === 'featured'}>{t('sort_featured', lang)}</option>
            <option value="az"       selected={sortParam === 'az'}      >{t('sort_az', lang)}</option>
            <option value="price_lo" selected={sortParam === 'price_lo'}>{t('sort_price_lo', lang)}</option>
            <option value="price_hi" selected={sortParam === 'price_hi'}>{t('sort_price_hi', lang)}</option>
          </select>
        </form>
      </div>
    </div>

    <!-- Active filter chips -->
    {(qParam) && (
      <div class="chips-row">
        {qParam && (
          <a href={buildUrl({ ...currentParams, q: '' })} class="chip active">
            "{qParam}"
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </a>
        )}
        <a href="/catalogo" class="chip">{t('filter_clear', lang)}</a>
      </div>
    )}

    <!-- Product grid -->
    {products.length === 0 ? (
      <div class="center" style="padding:70px 0;color:var(--gray);">
        <p style="margin-bottom:16px;">{t('no_results', lang)}</p>
        <a href="/catalogo" class="btn btn-outline">{t('filter_clear', lang)}</a>
      </div>
    ) : (
      <div class="prod-grid cols4">
        {products.map(p => <ProductCard product={p} lang={lang} />)}
      </div>
    )}

  </div>

</BaseLayout>

<style>
  /* Category filter bar */
  .cat-filter-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 12px 0;
  }
  .cat-filter-scroll::-webkit-scrollbar { display: none; }

  .cat-filter-bar {
    display: flex;
    gap: 10px;
    white-space: nowrap;
  }

  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 999px;
    border: 1.5px solid var(--line-2);
    background: #fff;
    color: var(--navy);
    font-size: .88rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: .16s var(--ease);
    cursor: pointer;
  }
  .cat-pill:hover {
    border-color: var(--navy);
    background: var(--mist);
  }
  .cat-pill-active {
    background: var(--navy) !important;
    border-color: var(--navy) !important;
    color: #fff !important;
  }
  .cat-pill-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--mist);
    flex: none;
    overflow: hidden;
  }
  .cat-pill-active .cat-pill-icon {
    background: rgba(255,255,255,.18);
  }
  .cat-pill-icon-svg { background: transparent !important; }

  /* Product grid */
  .prod-grid.cols4 { grid-template-columns: repeat(4, 1fr); }

  @media(max-width:1100px) {
    .prod-grid.cols4 { grid-template-columns: repeat(3, 1fr); }
  }
  @media(max-width:780px) {
    .prod-grid.cols4 { grid-template-columns: repeat(2, 1fr); }
    .catalog-bar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .catalog-bar .ct { font-size: .85rem; }
    .catalog-bar .select { width: 100%; box-sizing: border-box; }
  }
  @media(max-width:480px) {
    .prod-grid.cols4 { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }
</style>
