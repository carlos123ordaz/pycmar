---
import CheckoutForm from '../../components/CheckoutForm.tsx';
import type { Lang } from '../../lib/i18n';

const lang: Lang = Astro.locals.lang ?? 'es';

const labels: Record<Lang, { title: string; back: string; subtitle: string }> = {
  es: { title: 'Checkout — Pycmar', back: 'Volver al catálogo', subtitle: 'Completa tu pedido' },
  en: { title: 'Checkout — Pycmar', back: 'Back to catalog',   subtitle: 'Complete your order' },
  zh: { title: '结账 — Pycmar',      back: '返回目录',            subtitle: '完成您的订单' },
};
const l = labels[lang];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{l.title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: "Hanken Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f5f7fa;
    color: #0B1F3B;
    font-size: 15px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  button { font-family: inherit; cursor: pointer; }
  a { color: inherit; text-decoration: none; }
  input, select, textarea { font-family: inherit; }
  img { display: block; max-width: 100%; }

  /* ---- Header ---- */
  .co-header {
    background: #0B1F3B;
    padding: 0 clamp(16px, 5vw, 48px);
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .co-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -.02em;
  }
  .co-logo-mark {
    width: 32px; height: 32px;
    border-radius: 9px;
    background: #10B981;
    display: flex; align-items: center; justify-content: center;
  }
  .co-logo-mark svg { width: 18px; height: 18px; color: #06281c; }
  .co-back-link {
    font-size: .84rem;
    font-weight: 600;
    color: rgba(255,255,255,.55);
    display: flex; align-items: center; gap: 5px;
    transition: .15s;
  }
  .co-back-link:hover { color: #fff; }
  .co-back-link svg { width: 14px; height: 14px; }

  /* ---- Page ---- */
  .co-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(24px, 5vw, 48px) clamp(16px, 4vw, 32px) 80px;
  }
  .co-page-title {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -.03em;
    color: #0B1F3B;
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  /* ---- Grid ---- */
  .co-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    grid-template-areas: "right left";
    gap: 32px;
    align-items: start;
  }

  .co-left  { grid-area: left;  }
  .co-right { grid-area: right; }

  @media (max-width: 860px) {
    .co-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "left" "right";
    }
  }

  /* ---- Card wrapper ---- */
  .co-left, .co-right {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e4e9f0;
    box-shadow: 0 2px 8px rgba(11,31,59,.05);
    padding: clamp(20px, 3vw, 32px);
  }

  .co-section-title {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -.01em;
    color: #0B1F3B;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid #e4e9f0;
  }

  /* ---- Items ---- */
  .co-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .co-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #f0f4f8;
  }
  .co-item:last-child { border-bottom: none; }
  .co-item-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .co-item-name {
    font-weight: 700;
    font-size: .93rem;
    color: #0B1F3B;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .co-item-qty {
    font-size: .78rem;
    color: #6B7280;
    font-weight: 600;
  }
  .co-item-price {
    font-weight: 800;
    font-size: .96rem;
    color: #0B1F3B;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---- Totals ---- */
  .co-totals {
    margin-top: 18px;
    border-top: 1px solid #e4e9f0;
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .co-total-row {
    display: flex;
    justify-content: space-between;
    font-size: .9rem;
    color: #6B7280;
  }
  .co-igv { color: #9aa3b0; font-size: .84rem; }
  .co-grand {
    font-size: 1.15rem;
    font-weight: 800;
    color: #0B1F3B;
    margin-top: 4px;
    padding-top: 10px;
    border-top: 2px solid #0B1F3B;
  }

  /* ---- Pay button ---- */
  .co-pay-btn {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6em;
    width: 100%;
    padding: 1em 1.6em;
    font-size: 1rem;
    font-weight: 800;
    border-radius: 12px;
    border: none;
    background: #10B981;
    color: #06281c;
    cursor: pointer;
    transition: .2s;
  }
  .co-pay-btn:hover:not(:disabled) {
    background: #0c9b6c;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(16,185,129,.3);
  }
  .co-pay-btn:disabled { opacity: .55; cursor: not-allowed; }

  /* ---- Secure badge ---- */
  .co-secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    font-size: .76rem;
    color: #9aa3b0;
    font-weight: 600;
    margin-top: 14px;
  }

  /* ---- Error ---- */
  .co-error {
    background: #fef2f2;
    border: 1px solid rgba(239,68,68,.3);
    border-radius: 10px;
    padding: 10px 14px;
    color: #ef4444;
    font-size: .85rem;
    font-weight: 600;
    margin-top: 16px;
  }

  /* ---- Loading / Empty ---- */
  .co-loading {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 48px 24px;
    color: #6B7280;
    font-weight: 600;
  }
  .co-empty {
    text-align: center;
    padding: 64px 24px;
    color: #6B7280;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .co-empty p { font-weight: 600; font-size: 1rem; }

  /* ---- Spinner ---- */
  .co-spinner {
    width: 18px; height: 18px;
    border: 2.5px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
  }
  .co-loading .co-spinner {
    border: 2.5px solid #e4e9f0;
    border-top-color: #10B981;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ---- Stripe overrides ---- */
  .StripeElement {
    padding: 14px;
    border: 1.5px solid #d7dee8;
    border-radius: 9px;
    background: #fff;
    transition: .16s;
  }
  .StripeElement--focus { border-color: #10B981; box-shadow: 0 0 0 3px rgba(16,185,129,.15); }
  .StripeElement--invalid { border-color: #ef4444; }
</style>

<!-- Header -->
<header class="co-header">
  <a href="/" class="co-logo">
    <div class="co-logo-mark">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.46-3.44 6-7 6-3.56 0-7.56-2.54-8.5-6z"/>
        <path d="M18 12h.01"/>
        <path d="M6.5 12c-1-2-2.5-3-4.5-3s-3 1-3 3 1 3 3 3 3.5-1 4.5-3z"/>
      </svg>
    </div>
    Pycmar
  </a>
  <a href="/catalogo" class="co-back-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    {l.back}
  </a>
</header>

<!-- Content -->
<main class="co-page">
  <h1 class="co-page-title">{l.subtitle}</h1>
  <CheckoutForm client:load lang={lang} />
</main>

</body>
</html>
