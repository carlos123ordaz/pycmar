---
import CheckoutForm from '../../components/CheckoutForm.tsx';
import type { Lang } from '../../lib/i18n';

const lang: Lang = Astro.locals.lang ?? 'es';

const labels: Record<Lang, { title: string; back: string; subtitle: string; notes: string[] }> = {
  es: {
    title: 'Checkout — Pycmar', back: 'Volver al catálogo', subtitle: 'Completa tu pedido',
    notes: ['Entrega en 2 a 3 días hábiles', 'Te enviaremos un correo de confirmación al finalizar tu compra'],
  },
  en: {
    title: 'Checkout — Pycmar', back: 'Back to catalog', subtitle: 'Complete your order',
    notes: ['Delivery in 2 to 3 business days', 'We will send you a confirmation email once your order is placed'],
  },
  zh: {
    title: '结账 — Pycmar', back: '返回目录', subtitle: '完成您的订单',
    notes: ['2至3个工作日内送达', '下单后我们将向您发送确认邮件'],
  },
};
const l = labels[lang];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#0B1F3B" />
  <title>{l.title}</title>
  <link rel="icon"             type="image/x-icon" href="/favicon.ico" />
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon"             type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: "Hanken Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f5f7fa;
    color: #0B1F3B;
    font-size: 15px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  button { font-family: inherit; cursor: pointer; }
  a { color: inherit; text-decoration: none; }
  input, select, textarea { font-family: inherit; }
  img { display: block; max-width: 100%; }

  /* ---- Header ---- */
  .co-header {
    background: #0B1F3B;
    padding: 0 clamp(16px, 5vw, 48px);
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .co-logo { display: flex; align-items: center; }
  .co-logo img { height: 32px; width: auto; }
  .co-back-link {
    font-size: .84rem;
    font-weight: 600;
    color: rgba(255,255,255,.55);
    display: flex; align-items: center; gap: 5px;
    transition: .15s;
  }
  .co-back-link:hover { color: #fff; }
  .co-back-link svg { width: 14px; height: 14px; }

  /* ---- Page ---- */
  .co-page {
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 48px) clamp(24px, 4vw, 56px) 100px;
  }

  /* ---- Grid ---- */
  .co-grid {
    display: grid;
    grid-template-columns: 1fr 480px;
    grid-template-areas: "left right";
    gap: 36px;
    align-items: start;
  }

  /* left = billing form, right = summary + payment stack */
  .co-left        { grid-area: left;  }
  .co-right-stack { grid-area: right; display: flex; flex-direction: column; gap: 24px; }

  @media (max-width: 1060px) {
    .co-grid { grid-template-columns: 1fr 420px; }
  }
  @media (max-width: 900px) {
    .co-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "left" "right"; /* billing first on mobile */
      gap: 16px;
    }
  }

  /* ---- Card wrapper ---- */
  .co-card, .co-left {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #e4e9f0;
    box-shadow: 0 2px 10px rgba(11,31,59,.06);
    padding: clamp(24px, 3vw, 40px);
  }

  .co-section-title {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -.01em;
    color: #0B1F3B;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid #e4e9f0;
  }

  /* ---- Items ---- */
  .co-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .co-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #f0f4f8;
  }
  .co-item:last-child { border-bottom: none; }
  .co-item-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .co-item-name {
    font-weight: 700;
    font-size: .93rem;
    color: #0B1F3B;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .co-item-qty {
    font-size: .78rem;
    color: #6B7280;
    font-weight: 600;
  }
  .co-item-price {
    font-weight: 800;
    font-size: .96rem;
    color: #0B1F3B;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---- Totals ---- */
  .co-totals {
    margin-top: 18px;
    border-top: 1px solid #e4e9f0;
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .co-total-row {
    display: flex;
    justify-content: space-between;
    font-size: .9rem;
    color: #6B7280;
  }
  .co-igv { color: #9aa3b0; font-size: .84rem; }
  .co-grand {
    font-size: 1.15rem;
    font-weight: 800;
    color: #0B1F3B;
    margin-top: 4px;
    padding-top: 10px;
    border-top: 2px solid #0B1F3B;
  }

  /* ---- Pay button ---- */
  .co-pay-btn {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6em;
    width: 100%;
    padding: 1em 1.6em;
    font-size: 1rem;
    font-weight: 800;
    border-radius: 12px;
    border: none;
    background: #25C7CA;
    color: #052e2e;
    cursor: pointer;
    transition: .2s;
  }
  .co-pay-btn:hover:not(:disabled) {
    background: #1dadb0;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(37,199,202,.3);
  }
  .co-pay-btn:disabled { opacity: .55; cursor: not-allowed; }

  /* ---- Secure badge ---- */
  .co-secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    font-size: .76rem;
    color: #9aa3b0;
    font-weight: 600;
    margin-top: 14px;
  }

  /* ---- Error ---- */
  .co-error {
    background: #fef2f2;
    border: 1px solid rgba(239,68,68,.3);
    border-radius: 10px;
    padding: 10px 14px;
    color: #ef4444;
    font-size: .85rem;
    font-weight: 600;
    margin-top: 16px;
  }

  /* ---- Loading / Empty ---- */
  .co-loading {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 48px 24px;
    color: #6B7280;
    font-weight: 600;
  }
  .co-empty {
    text-align: center;
    padding: 64px 24px;
    color: #6B7280;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .co-empty p { font-weight: 600; font-size: 1rem; }

  /* ---- Spinner ---- */
  .co-spinner {
    width: 18px; height: 18px;
    border: 2.5px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
  }
  .co-loading .co-spinner {
    border: 2.5px solid #e4e9f0;
    border-top-color: #25C7CA;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* right-stack is defined inline in the Grid block above */

  /* ---- Billing fields ---- */
  .co-fields-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  /* Prevent iOS Safari from zooming on input focus */
  @media (max-width: 768px) {
    .co-input { font-size: 16px; }
  }

  /* Mobile spacing & layout */
  @media (max-width: 640px) {
    .co-page { padding: 14px 16px 56px; }
    .co-card, .co-left { padding: 20px 18px; border-radius: 14px; }
    .co-section-title { font-size: .9rem; margin-bottom: 14px; padding-bottom: 10px; }
    .co-grand { font-size: 1rem; }
    /* Bank / Yape info rows: stack label above value so long account numbers don't overflow */
    .co-info-row { flex-direction: column; align-items: flex-start; gap: 2px; }
    .co-info-value { text-align: left; word-break: break-all; }
    .co-totals { gap: 6px; }
    .co-pay-btn { font-size: .95rem; padding: .9em 1.4em; }
  }

  @media (max-width: 480px) {
    .co-fields-grid { grid-template-columns: 1fr; }
  }
  .co-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
  }
  .co-field:last-child { margin-bottom: 0; }
  .co-label {
    font-size: .82rem;
    font-weight: 700;
    color: #374151;
    letter-spacing: .01em;
  }
  .co-required { color: #ef4444; }
  .co-input {
    padding: 10px 13px;
    border: 1.5px solid #d7dee8;
    border-radius: 9px;
    font-size: .9rem;
    color: #0B1F3B;
    background: #fff;
    transition: .15s;
    outline: none;
  }
  .co-input:focus { border-color: #25C7CA; box-shadow: 0 0 0 3px rgba(37,199,202,.15); }
  .co-input--error { border-color: #ef4444; }
  .co-field-error { font-size: .78rem; color: #ef4444; font-weight: 600; }

  /* ---- Payment method tabs ---- */
  .co-method-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 4px;
  }
  .co-method-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 6px;
    border: 1.5px solid #d7dee8;
    border-radius: 10px;
    background: #f5f7fa;
    font-size: .84rem;
    font-weight: 700;
    color: #6B7280;
    cursor: pointer;
    transition: .15s;
  }
  @media (max-width: 360px) {
    .co-page { padding: 10px 12px 56px; }
    .co-card, .co-left { padding: 16px 14px; }
    .co-method-tab { font-size: .72rem; gap: 3px; }
  }
  .co-method-tab:hover { border-color: #25C7CA; color: #0B1F3B; }
  .co-method-tab--active {
    background: #e5fafa;
    border-color: #25C7CA;
    color: #074f51;
  }

  /* ---- Manual payment info block ---- */
  .co-payment-info {
    background: #f5f7fa;
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .co-info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    font-size: .86rem;
  }
  .co-info-label { color: #6B7280; font-weight: 600; }
  .co-info-value { color: #0B1F3B; font-weight: 700; text-align: right; }
  .co-info-mono { font-family: monospace; letter-spacing: .04em; }
  .co-info-amount { color: #0a9fa2; font-size: 1rem; }
  .co-info-note { font-size: .78rem; color: #9aa3b0; line-height: 1.5; }

  /* ---- Voucher upload ---- */
  .co-upload-area {
    display: block;
    border: 2px dashed #d7dee8;
    border-radius: 10px;
    cursor: pointer;
    transition: .15s;
    overflow: hidden;
  }
  .co-upload-area:hover { border-color: #25C7CA; }
  .co-upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 24px 16px;
    color: #9aa3b0;
    font-size: .84rem;
    font-weight: 600;
    text-align: center;
  }
  .co-upload-placeholder svg { color: #c4cdd8; }
  .co-upload-name { color: #25C7CA; font-size: .8rem; }
  .co-upload-preview {
    width: 100%;
    max-height: 180px;
    object-fit: cover;
    display: block;
  }

  /* ---- Success card ---- */
  .co-success-card {
    background: #fff;
    border-radius: 20px;
    border: 1px solid #e4e9f0;
    box-shadow: 0 4px 24px rgba(11,31,59,.07);
    padding: clamp(36px,6vw,64px) clamp(28px,5vw,56px);
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .co-success-icon {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: #c6f3f4;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .co-success-icon svg { color: #0a9fa2; }
  .co-success-heading { font-size: 1.6rem; font-weight: 800; letter-spacing: -.03em; color: #0B1F3B; margin-bottom: 10px; }
  .co-success-sub { color: #6B7280; font-size: .96rem; line-height: 1.6; margin-bottom: 20px; max-width: 380px; }
  .co-order-ref {
    background: #f5f7fa; border-radius: 8px; padding: 10px 18px;
    font-family: monospace; font-size: .88rem; font-weight: 700; letter-spacing: .06em;
    color: #0B1F3B; margin-bottom: 24px;
  }
  .co-wa-note {
    margin-top: 20px;
    font-size: .82rem;
    color: #9aa3b0;
    line-height: 1.5;
  }
  .co-wa-link {
    color: #25D366;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .co-wa-link:hover { color: #1aab52; }

  /* ---- Page header bar ---- */
  .co-page-banner {
    background: #fff;
    border-bottom: 1px solid #e4e9f0;
    box-shadow: 0 2px 8px rgba(11,31,59,.05);
  }
  .co-page-header {
    max-width: 1320px;
    margin: 0 auto;
    padding: 18px clamp(24px, 4vw, 56px);
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .co-page-title {
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    font-weight: 800;
    letter-spacing: -.03em;
    color: #0B1F3B;
    white-space: nowrap;
    margin: 0;
  }
  .co-header-divider {
    width: 1px;
    height: 28px;
    background: #e4e9f0;
    flex-shrink: 0;
  }
  @media (max-width: 640px) { .co-header-divider { display: none; } }
  .co-notes {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 16px;
    flex: 1;
    min-width: 0;
  }
  .co-note {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: .8rem;
    font-weight: 600;
    color: #6B7280;
  }
  .co-note svg { flex-shrink: 0; width: 13px; height: 13px; color: #25C7CA; }
  .co-note-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: #d7dee8;
    flex-shrink: 0;
  }
  @media (max-width: 540px) {
    .co-note-dot { display: none; }
    .co-page-header { padding: 12px 16px; gap: 8px; }
    .co-notes { display: none; } /* save vertical space on small screens */
    .co-header-divider { display: none; }
  }

  /* ---- Stripe overrides ---- */
  .StripeElement {
    padding: 14px;
    border: 1.5px solid #d7dee8;
    border-radius: 9px;
    background: #fff;
    transition: .16s;
  }
  .StripeElement--focus { border-color: #25C7CA; box-shadow: 0 0 0 3px rgba(37,199,202,.15); }
  .StripeElement--invalid { border-color: #ef4444; }
</style>

<!-- Header -->
<header class="co-header">
  <a href="/" class="co-logo">
    <img src="/assets/logo-white.png" alt="Pycmar" />
  </a>
  <a href="/catalogo" class="co-back-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    {l.back}
  </a>
</header>

<!-- Page header banner (full width, flush under sticky header) -->
<div class="co-page-banner">
  <div class="co-page-header">
    <h1 class="co-page-title">{l.subtitle}</h1>
    <div class="co-header-divider"></div>
    <div class="co-notes">
      {l.notes.map((note, i) => (
        <>
          {i > 0 && <span class="co-note-dot"></span>}
          <div class="co-note">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {note}
          </div>
        </>
      ))}
    </div>
  </div>
</div>

<!-- Content -->
<main class="co-page">
  <CheckoutForm client:load lang={lang} />
</main>

</body>
</html>
